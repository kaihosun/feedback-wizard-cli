{
  "name": "@feedback-wizard/cli",
  "version": "0.1.0",
  "description": "Install a feedback/bug-reporting wizard in any Next.js project — zero human intervention",
  "type": "module",
  "author": "kaihosun (https://github.com/kaihosun)",
  "license": "MIT",
  "homepage": "https://github.com/kaihosun/feedback-wizard-cli#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaihosun/feedback-wizard-cli.git"
  },
  "bugs": {
    "url": "https://github.com/kaihosun/feedback-wizard-cli/issues"
  },
  "keywords": [
    "nextjs",
    "feedback",
    "bug-reporting",
    "wizard",
    "cli",
    "scaffolding",
    "supabase",
    "prisma",
    "shadcn"
  ],
  "bin": {
    "feedback-wizard": "./dist/bin/wizard.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "src/templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test tests/**/*.test.ts",
    "test:fixtures": "node --import tsx/esm scripts/test-fixtures.ts",
    "prepublishOnly": "npm run build && npm run typecheck",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "execa": "^8.0.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.0",
    "inquirer": "^9.2.0",
    "ora": "^8.0.1",
    "ts-morph": "^22.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.0",
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
